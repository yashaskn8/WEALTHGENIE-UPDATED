# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wealthgenie?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_64_char_hex_secret_here_replace_this_with_a_real_secret_key_64ch
JWT_EXPIRES_IN=7d

# Redis Cache
REDIS_URL=redis://localhost:6379

# ML Microservice
ML_SERVICE_URL=http://localhost:8000

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
